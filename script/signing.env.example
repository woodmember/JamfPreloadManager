# Copy this file to script/signing.env and set the values for your Apple developer team.
# script/signing.env is git-ignored so your identities are not published.

# Sign the .app bundle for Developer ID distribution.
APP_SIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# Sign the installer package (.pkg).
PKG_SIGN_IDENTITY="Developer ID Installer: Your Name (TEAMID)"

# Optional hardened-runtime entitlements plist for the app bundle.
# APP_ENTITLEMENTS="/absolute/path/to/JamfPreloadManager.entitlements"

# Optional installer package name (defaults to "Jamf Preload Manager.pkg").
# PKG_NAME="Jamf Preload Manager.pkg"

# Optional notarization settings (used with: ./script/build_pkg.sh --notarize)
# Create the notary profile once with:
#   xcrun notarytool store-credentials "AC_NOTARY" \
#     --key /path/to/AuthKey_XXXXXX.p8 --key-id XXXXX --issuer XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
# NOTARY_KEYCHAIN_PROFILE="AC_NOTARY"
# NOTARY_KEYCHAIN_PATH="$HOME/Library/Keychains/login.keychain-db"
